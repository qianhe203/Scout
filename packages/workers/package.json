  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@scout/harness": "workspace:*",
    "@scout/shared": "workspace:*"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
