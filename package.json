{
  "name": "scout",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter api --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @scout/shared build && pnpm --filter @scout/harness build && pnpm --filter @scout/workers build && pnpm --filter api build",
    "build:web": "pnpm --filter @scout/shared build && pnpm --filter web build",
    "build:railway": "pnpm run build:api && NEXT_PUBLIC_HARNESS_API_URL= pnpm run build:web",
    "start:railway": "node scripts/start-railway.mjs",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "vitest": "^3.0.5"
  }
}
