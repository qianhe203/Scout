# LLM — cloud OpenAI (Railway / production)
LLM_PROVIDER=openai
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
# OPENAI_JSON_MODE=true

# Alternative: Anthropic
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-sonnet-4-20250514

# Hackathon venue only — OpenAI-compatible LAN gateway (do not use on Railway)
# OPENAI_API_BASE=http://10.10.2.113:4000/v1
# LLM_MODEL=qwen3-coder

# ICP web research — pick ONE (Tavily recommended; free tier is enough for demo)
TAVILY_API_KEY=
# SERPER_API_KEY=

# Creator discovery (optional — seed fallback if missing)
INFLUENCERS_CLUB_API_KEY=
# Log each POST /public/v1/discovery/ body + result count to API stdout
INFLUENCERS_CLUB_DEBUG=true
# Minimal broadening retry (off by default while debugging)
# INFLUENCERS_CLUB_RETRY=true

# API server
PORT=3001
RUNS_DIR=./runs
RUN_TOKEN_BUDGET=50000
RUN_COST_CAP=2.00
WORKER_MODE=llm
CORS_ORIGIN=http://localhost:3000

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=scout-api

# Next.js (apps/web/.env.local)
# NEXT_PUBLIC_HARNESS_API_URL=http://localhost:3001
