# LLM (Railway / local API)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Creator discovery
INFLUENCERS_CLUB_API_KEY=

# ICP web research
TAVILY_API_KEY=
# SERPER_API_KEY=

# API server
PORT=3001
RUNS_DIR=./runs
RUN_TOKEN_BUDGET=50000
RUN_COST_CAP=2.00
WORKER_MODE=llm
CORS_ORIGIN=http://localhost:3000

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=scout-api

# Next.js (apps/web/.env.local)
# NEXT_PUBLIC_HARNESS_API_URL=http://localhost:3001
